# Application
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-64-char-hex-string
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/elevate_estate

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Session
SESSION_COOKIE_NAME=ee_session
SESSION_TTL_SECONDS=604800  # 7 days
SESSION_SECURE_COOKIE=false  # set true in production

# Email / SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_your_api_key_here
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Elevate Estate

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=elevate-estate-media
S3_PRESIGNED_URL_EXPIRY=3600

# Sentry (optional)
SENTRY_DSN=

# Invitation tokens
INVITATION_SECRET=change-me-invitation-secret
INVITATION_TTL_HOURS=72

# Feature flags
REQUIRE_EMAIL_VERIFICATION=true
